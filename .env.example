# Personal Buffett · Environment Variables
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to version control — it contains secrets.

# ── Flask ──────────────────────────────────────────────
# Generate a strong key: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-secret

# Optional: override SQLite path for deployment volumes
# Example on Railway: /data/radar.db
RADAR_DB_PATH=

# ── Groq AI — free LLM for Buffett analysis letters ───
# Sign up and get a free key at: https://console.groq.com
GROQ_API_KEY=

# ── Google OAuth (optional — enables Google Sign-In) ───
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:5001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Discord (optional — push notifications) ────────────
# Create a bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── Server酱 / WeCom (optional — WeChat push) ─────────
# Get key at: https://sct.ftqq.com
SERVERCHAN_KEY=
